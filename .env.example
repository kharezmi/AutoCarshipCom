# Copy this file to ".env.local" in the same folder (web/), then edit values.
# Command (PowerShell, from the "web" folder):  Copy-Item .env.example .env.local

# --- Blog images ---
# Uploaded images are saved under web/public/blog-uploads/ (served as /blog-uploads/...).

# --- Blog admin (required to sign in at /admin/login) ---
BLOG_ADMIN_PASSWORD=choose-a-strong-password
# Min 16 characters; use a long random string in production.
BLOG_ADMIN_SECRET=replace-with-at-least-16-random-characters

# --- Site URL (optional; used for canonical URLs, sitemap, Open Graph) ---
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Quote & contact emails (optional) ---
# RESEND_API_KEY=
# QUOTE_NOTIFY_EMAIL=you@yourdomain.com
# RESEND_FROM_EMAIL=AutoCarShip <newsletter@yourdomain.com>

# --- MsgPlane tracking (optional) ---
# MSGPLANE_TRACKING_API_URL=
# MSGPLANE_API_KEY=
# MSGPLANE_PUBLIC_TRACKING_URL_TEMPLATE=https://example.com/track?ref={{orderId}}

# --- Live chat (optional; Crisp: https://crisp.chat/, agents answer in their inbox) ---
# Create a website in Crisp, then Settings > Website Settings > Website ID.
# NEXT_PUBLIC_CRISP_WEBSITE_ID=your-uuid-here
